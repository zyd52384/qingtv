<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true">

    <!-- ExoPlayer 播放器 -->
    <com.google.android.exoplayer2.ui.StyledPlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center" />

    <!-- 加载进度 -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="center"
        android:indeterminateTint="#00aaff"
        android:visibility="gone" />

    <!-- ═══ 悬浮频道条 — 视频上方半透明底边 ═══ -->
    <LinearLayout
        android:id="@+id/channelBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:background="#cc000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvChannelBarName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CCTV-1 综合"
            android:textColor="#ffffff"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvChannelBarInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="央视 · CH1"
            android:textColor="#8899aa"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- ═══ 频道列表覆盖层 ═══ -->
    <LinearLayout
        android:id="@+id/channelOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#e6101a2e"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- 标题栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#16213e"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="轻看TV · 频道列表"
                android:textColor="#ffffff"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_gravity="center_vertical"
                android:text="（方向键选择，OK键确认）"
                android:textColor="#556677"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- 频道网格 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/channelGrid"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:padding="16dp" />

        <!-- 底部提示 -->
        <TextView
            android:id="@+id/tvOverlayInfo"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="#16213e"
            android:gravity="center"
            android:text="按数字键快速换台 · 上下键切台"
            android:textColor="#00aaff"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- ═══ 顶部返回键 ═══ -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#cc0d0d0d"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:visibility="visible">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:background="@drawable/btn_bg"
            android:src="@drawable/ic_back"
            android:contentDescription="返回" />

        <TextView
            android:id="@+id/tvTopTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="轻看TV"
            android:textColor="#ffffff"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- ═══ 底部免费版升级条 ═══ -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_gravity="bottom"
        android:background="#cc0d0d0d"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvVersionInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="轻看TV · 免费版"
            android:textColor="#8899aa"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnUpgrade"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/btn_upgrade"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:text="开通全屏 →"
            android:textColor="#ffffff"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

</FrameLayout>
